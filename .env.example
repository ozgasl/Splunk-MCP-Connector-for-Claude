# Splunk MCP Connector — environment variable reference
# These are used by the setup wizard and validate command.
# Copy to .env and fill in your values (never commit .env to git).

# Splunk MCP Server endpoint (from the Splunk MCP Server app)
SPLUNK_MCP_ENDPOINT=https://your-splunk-host:8089/services/mcp

# Encrypted MCP token (generated in the Splunk MCP Server app)
# This token is ONLY valid for MCP — it cannot be used for direct Splunk REST API calls.
SPLUNK_MCP_TOKEN=

# Set to "false" to skip TLS certificate verification (for self-signed / on-prem certs)
SPLUNK_TLS_VERIFY=true
